{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  // 总开关 —— 启用/禁用 DCP 插件（默认: true）
  "enabled": true,

  // 将调试日志写入 ~/.config/opencode/logs/dcp/，用于排查问题（默认: false）
  "debug": true,

  // 裁剪通知的详细程度：
  //   "off"      — 不通知
  //   "minimal"  — 简短一行摘要（默认）
  //   "detailed" — 完整展示被裁剪/压缩的内容明细
  "pruneNotification": "detailed",

  // 裁剪通知的展示位置：
  //   "chat"  — 注入到对话中（默认）
  //   "toast" — 以系统 toast 形式显示在 TUI 界面
  "pruneNotificationType": "toast",

  // 斜杠命令 (/dcp) 配置
  "commands": {
    // 注册 /dcp 斜杠命令（context, stats, sweep, manual, compress, decompress, recompress）
    "enabled": true,
    // 执行 /dcp sweep 时额外保护不被裁剪的工具名。
    // 支持 glob 通配符（* 和 ?）。与内置默认列表合并（并集叠加，非替换）：
    //   task, skill, todowrite, todoread, compress, batch, plan_enter, plan_exit, write, edit
    "protectedTools": [
      "sequential-thinking",
      "background_output",
      "task_*",
      "memory_*",
      "session_*"
    ]
  },

  // 手动模式 —— 禁用自主上下文管理；
  // compress 工具仅在通过 /dcp 命令显式触发时才运行
  "manualMode": {
    "enabled": false,
    // 为 true 时，自动策略（去重、写入覆盖、错误清理）
    // 在手动模式下仍然继续运行（默认: true）
    "automaticStrategies": true
  },

  // 轮次保护 —— 防止工具输出在调用后 N 轮消息内被裁剪，
  // 确保最近使用的结果保留在上下文中（默认: 启用, 6 轮）
  "turnProtection": {
    "enabled": true,
    "turns": 8
  },

  // 文件保护的 glob 模式 —— 匹配的文件的读/写工具输出永远不会被裁剪。
  // 模式基于项目根目录的相对路径匹配。
  // 多层配置之间合并（并集叠加）—— 项目级模式会追加到全局配置上。
  "protectedFilePatterns": [
    "openspec/**",
    "**/AGENTS.md"
  ],

  // 实验性功能 —— 可能在未来版本中变更或移除
  "experimental": {
    // 允许 DCP 在子代理（task()）会话中处理，而不仅限于主会话（默认: false）
    "allowSubAgents": true,
    // 启用用户可编辑的 prompt 覆盖，从 dcp-prompts/ 目录加载。
    // 搜索顺序：项目 .opencode/dcp-prompts/ → 全局 ~/.config/opencode/dcp-prompts/
    "customPrompts": false
  },

  // 统一的 compress 工具配置。
  // 控制替代旧版 distill/compress/prune 工具的单一 compress 工具。
  "compress": {
    // compress 工具的权限模式：
    //   "allow" — 工具可用，无需确认（默认）
    //   "ask"   — 工具可用，每次压缩前提示用户确认
    //   "deny"  — 工具不注册，完全禁用
    "permission": "allow",

    // 压缩模式：
    //   "range"   — 按范围压缩，将一段消息范围合并为摘要（默认）
    //   "message" — 按消息压缩（实验性），对单条消息逐条压缩
    "mode": "range",

    // 在裁剪通知中包含压缩摘要（默认: true）
    "showCompression": false,

    // 软上限阈值 —— 当上下文使用量超过此值时，DCP 会在系统提示中注入强烈的压缩提醒。
    // 接受绝对 token 数（数字）或模型上下文窗口的百分比（"X%"）。（默认: "70%"）
    "maxContextLimit": "70%",

    // 软下限阈值 —— 当上下文使用量低于此值时，压缩提醒被抑制。
    // 格式同 maxContextLimit。（默认: "20%"）
    "minContextLimit": "30%",

    // 摘要缓冲区 —— 为 true 时，活跃压缩摘要的 token 可超出 maxContextLimit，
    // 有效扩展上下文容量以容纳摘要内容。（默认: true）
    "summaryBuffer": true,

    // 按模型单独覆盖 maxContextLimit，键为精确的 "provider/model" 字符串。
    // 适用于不同模型有不同上下文窗口大小或成本考量的情况。
    "modelMaxLimits": {
      "anthropic/claude-opus-4-6": "65%",
      "anthropic/claude-sonnet-4-6": "65%",
      "anthropic/claude-haiku-4-5": "65%",
      "openai/gpt-5.2": "65%",
      "openai/gpt-5.3-codex": "65%",
      "openai/gpt-5.4": "65%"
    },

    // 按模型单独覆盖 minContextLimit（键格式同 modelMaxLimits）
    "modelMinLimits": {},

    // 超过 maxContextLimit 后，上下文限制提醒的触发频率。
    // 1 = 每次模型请求都触发，5 = 每 5 次触发一次，依此类推。（默认: 3，最小值: 1）
    "nudgeFrequency": 3,

    // 用户消息之后等待多少条助手消息才注入压缩提醒。
    // 值越大，活跃工作期间的干扰越少。（默认: 5）
    "iterationNudgeThreshold": 10,

    // 控制用户消息后触发压缩的积极程度：
    //   "strong" — 更积极地触发压缩（默认）
    //   "soft"   — 温和提醒，压缩可能性更低
    "nudgeForce": "strong",

    // 需要保护的工具名 —— 这些工具的已完成输出将被保留（附加到压缩摘要中）
    // 而不是被裁剪。支持 glob 通配符：* 匹配任意字符，? 匹配单个字符。
    // 与内置默认列表合并（并集叠加）：task, skill, todowrite, todoread, compress, batch 等
    "protectedTools": [
      "sequential-thinking",
      "background_output",
      "task_*",
      "memory_*",
      "session_*"
    ],

    // 为 true 时，用户消息在压缩过程中永远不会丢失 ——
    // 始终完整保留或在摘要中引用。（默认: true）
    "protectUserMessages": false
  },

  // 自动裁剪策略 —— 在后台持续运行。
  // 当 manualMode.automaticStrategies 为 true 时，即使在手动模式下也会触发。
  "strategies": {
    // 去重 —— 移除重复/冗余的工具输出（例如同一文件被读取两次）
    "deduplication": {
      "enabled": true,
      // 额外保护不被去重裁剪的工具（支持 glob 通配符）
      "protectedTools": []
    },

    // 写入覆盖 —— 当被写入的文件随后被读取时，裁剪 write 工具的输入，
    // 因为写入内容已被读取结果所取代，变得冗余
    "supersedeWrites": {
      "enabled": true
    },

    // 错误清理 —— 在 N 轮之后裁剪返回错误的工具输入，
    // 防止过时的错误上下文占用上下文窗口
    "purgeErrors": {
      "enabled": true,
      // 等待多少轮之后裁剪出错工具的输入（默认: 3）
      "turns": 4,
      // 额外保护不被错误清理的工具（支持 glob 通配符）
      "protectedTools": ["background_output"]
    }
  }
}
