{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // ======================
    // 1. 编排规划与验证系列
    // ======================
    "sisyphus": {
      // 主编排器：委托任务编排分配、TODO、后台并行、动态组合技能，调用subagent
      // fallback：claude-opus-4-6 → gpt-5.3-codex
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      // 追加提示词：显式加载全局 AGENTS.md
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "hephaestus": {
      // 深度自主工作专用，长周期，深度任务
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.2"
      ],
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "oracle": {
      // 咨询/调试/架构专家：代码审查、复杂问题拆解，交互式问答
      // fallback：anthropic/claude-opus-4-6 → gpt-5.3-codex
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": [
        "openai/gpt-5.3-codex-spark"
      ],
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "variant": "high",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "multimodal-looker": {
      // 多模态分析：图片、PDF等
      // fallback：gpt-5.3-codex → claude-sonnet-4-6
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "prometheus": {
      // 战略规划：澄清需求、验证计划、复杂任务分解，推荐内部plan而不是和用户直接交互
      // fallback：claude-opus-4-6 → gpt-5.2
      "model": "anthropic/claude-opus-4-6",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.2"
      ],
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "metis": {
      // 预分析规划顾问：正式plan/执行前进行问题理解、风险与上下文分析，温度略高，探索更多方案
      // fallback：claude-opus-4-6 → gpt-5.2
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.2"
      ],
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "momus": {
      // 计划与结果验证：对计划/方案进行合理性检查和评审
      // fallback：gpt-5.3-codex → claude-opus-4-6
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "atlas": {
      // 高级编排器：全生命周期管理，任务路由，基于skills调度，全局会话级别的编排器，一般由内部逻辑/hook唤起
      // v3.14.0: 官方默认 sonnet（todo 编排器不需要 opus 级推理）
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.2"
      ],
      "variant": "high",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md\n仅做当前阶段所必需的最小修改，禁止无关改动、顺手重构和范围扩散。\n任务必须分阶段执行，每次只完成一个清晰、可验证的阶段目标。\n每个阶段完成后，必须先提交一个最小、完整、自洽的 commit，再进入下一阶段。\n禁止将多个阶段合并到同一个 commit 中。"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.3-codex",
      "fallback_models": [
        "openai/gpt-5.2"
      ],
      "variant": "high",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "librarian": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": [
        "openai/gpt-5.3-codex-spark"
      ],
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "variant": "high",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    }
  },
  "categories": {
    "visual-engineering": {
      // 视觉/前端/GUI：codex → opus
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "fallback_models": [
        "anthropic/claude-opus-4-6"
      ],
      "description": "Frontend, UI/UX, design, styling, animations, layout work",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "ultrabrain": {
      // 超大脑：opus → codex
      "model": "anthropic/claude-opus-4-6",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "description": "Complex logic, architecture decisions, algorithms, deep reasoning",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "deep": {
      // 深度执行：codex → opus
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "fallback_models": [
        "anthropic/claude-opus-4-6"
      ],
      "description": "Autonomous problem-solving, thorough research, end-to-end implementation",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "quick": {
      // 快速小活：gpt-5.4-mini → haiku
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "anthropic/claude-haiku-4-5"
      ],
      "description": "Trivial tasks, single-file changes, typo fixes, simple modifications",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6",
        "openai/gpt-5.3-codex"
      ],
      "variant": "high",
      "description": "General tasks, low to moderate effort",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "description": "General tasks, high effort and complexity",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "writing": {
      // 文本/写作：codex → sonnet
      "model": "openai/gpt-5.3-codex",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6"
      ],
      "description": "Documentation, prose, technical writing, creative content",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    },
    "artistry": {
      // 创意解法：非常规思路解决复杂问题
      "model": "anthropic/claude-opus-4-6",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "description": "Complex problem-solving with unconventional, creative approaches - beyond standard patterns",
      "prompt_append": "必须严格遵守 AGENTS.md 的要求: \nfile://~/.config/opencode/AGENTS.md"
    }
  },
  "git_master": {
    // 提交时携带 opencode 信息
    "commit_footer": false,
    "include_co_authored_by": false
  },
  "notification": {
    "force_enable": true
  },
  "background_task": {
    "defaultConcurrency": 20,
    "staleTimeoutMs": 1200000,
    "providerConcurrency": {
      "anthropic": 10,
      "openai": 15
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 10,
      "openai/gpt-5.3-codex": 20
    }
  },
  "disabled_mcps": [
    "websearch"
  ],
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "hashline_edit": true,
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "disable_omo_env": false
  },
  "_migrations": [
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4"
  ]
}
