{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // ======================
    // 1. 编排规划与验证系列
    // ======================
    "sisyphus": {
      // 主编排器：委托任务编排分配、TODO、后台并行、动态组合技能，调用subagent
      // fallback：claude-opus-4-6 → gpt-5.4 → gpt-5.3-codex
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": ["openai/gpt-5.4", "openai/gpt-5.3-codex"],
      "temperature": 0.1,
      // 追加提示词：显式加载全局 AGENTS.md
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "atlas": {
      // 高级编排器：全生命周期管理，任务路由，基于skills调度，全局会话级别的编排器，一般由内部逻辑/hook唤起
      // fallback：claude-opus-4-6 → gpt-5.4 → gpt-5.2
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": ["openai/gpt-5.4", "openai/gpt-5.2"],
      "temperature": 0.1,
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "prometheus": {
      // 战略规划：澄清需求、验证计划、复杂任务分解，推荐内部plan而不是和用户直接交互
      // fallback：claude-opus-4-6 → gpt-5.4 → gpt-5.2
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": ["openai/gpt-5.4", "openai/gpt-5.2"],
      "variant": "medium",
      "prompt_append": "file://~/.config/opencode/AGENTS.md",
      "temperature": 0.1
    },
    "metis": {
      // 预分析规划顾问：正式plan/执行前进行问题理解、风险与上下文分析，温度略高，探索更多方案
      // fallback：claude-opus-4-6 → gpt-5.4 → gpt-5.2
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": ["openai/gpt-5.4", "openai/gpt-5.2"],
      "temperature": 0.3,
      "prompt_append": "file://~/.config/opencode/AGENTS.md",
      "variant": "medium"
    },
    "momus": {
      // 计划与结果验证：对计划/方案进行合理性检查和评审
      // fallback：gpt-5.2 → gpt-5.4 → claude-opus-4-6
      "model": "openai/gpt-5.2",
      "fallback_models": ["openai/gpt-5.4", "anthropic/claude-opus-4-6"],
      "prompt_append": "file://~/.config/opencode/AGENTS.md",
      "temperature": 0.1
    },
    // ======================
    // 2. 执行系
    // ======================
    "hephaestus": {
      // 深度自主工作专用，长周期，深度任务
      // fallback：gpt-5.3-codex → gpt-5.4 → gpt-5.2
      "model": "openai/gpt-5.3-codex",
      "fallback_models": ["openai/gpt-5.4", "openai/gpt-5.2"],
      "temperature": 0.1,
      "variant": "medium",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    // ======================
    // 3. 顾问与检索系
    // ======================
    "oracle": {
      // 咨询/调试/架构专家：代码审查、复杂问题拆解，交互式问答
      // fallback：gpt-5.4 → gpt-5.2 → claude-opus-4-6
      "model": "openai/gpt-5.4",
      "fallback_models": ["openai/gpt-5.2", "anthropic/claude-opus-4-6"],
      "temperature": 0.1,
      "variant": "high",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "librarian": {
      // 文档检索：外部文档、库文档搜索
      // fallback：gpt-5.2 → gpt-5.3-codex-spark → claude-haiku-4-5
      "model": "openai/gpt-5.2",
      "fallback_models": ["openai/gpt-5.3-codex-spark", "anthropic/claude-haiku-4-5"],
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "explore": {
      // 代码库搜索：快速检索代码模式
      // fallback：gpt-5.3-codex-spark → gpt-5.2 → claude-haiku-4-5
      "model": "openai/gpt-5.3-codex-spark",
      "fallback_models": ["openai/gpt-5.2", "anthropic/claude-haiku-4-5"],
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "multimodal-looker": {
      // 多模态分析：图片、PDF等
      // fallback：gpt-5.2 → gpt-5.4 → claude-sonnet-4-6
      "model": "openai/gpt-5.2",
      "fallback_models": ["openai/gpt-5.4", "anthropic/claude-sonnet-4-6"],
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    }
  },
  "categories": {
    "visual-engineering": {
      // 视觉/前端/GUI：codex → opus → gpt-5.4
      "model": "openai/gpt-5.3-codex",
      "fallback_models": ["anthropic/claude-opus-4-6", "openai/gpt-5.4"],
      "variant": "medium",
      "description": "Frontend, UI/UX, design, styling, animations, layout work",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "ultrabrain": {
      // 超大脑：gpt-5.4 → codex → opus
      "model": "openai/gpt-5.4",
      "fallback_models": ["openai/gpt-5.3-codex", "anthropic/claude-opus-4-6"],
      "variant": "xhigh",
      "description": "Complex logic, architecture decisions, algorithms, deep reasoning",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "deep": {
      // 深度执行：codex → gpt-5.4 → opus
      "model": "openai/gpt-5.3-codex",
      "fallback_models": ["openai/gpt-5.4", "anthropic/claude-opus-4-6"],
      "variant": "medium",
      "description": "Autonomous problem-solving, thorough research, end-to-end implementation",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "quick": {
      // 快速小活：spark → gpt-5.2 → haiku
      "model": "openai/gpt-5.3-codex-spark",
      "fallback_models": ["openai/gpt-5.2", "anthropic/claude-haiku-4-5"],
      "temperature": 0.1,
      "description": "Trivial tasks, single-file changes, typo fixes, simple modifications",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "writing": {
      // 文本/写作：gpt-5.2 → sonnet → gpt-5.4
      "model": "openai/gpt-5.2",
      "fallback_models": ["anthropic/claude-sonnet-4-6", "openai/gpt-5.4"],
      "temperature": 0.5,
      "description": "Documentation, prose, technical writing, creative content",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    // 未指定低/高档位
    "unspecified-low": {
      "model": "openai/gpt-5.2",
      "fallback_models": ["anthropic/claude-sonnet-4-6", "openai/gpt-5.3-codex"],
      "description": "General tasks, low to moderate effort",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "fallback_models": ["anthropic/claude-opus-4-6", "openai/gpt-5.3-codex"],
      "variant": "high",
      "description": "General tasks, high effort and complexity",
      "prompt_append": "file://~/.config/opencode/AGENTS.md"
    }
  },
  "git_master": {
    // 提交时携带 opencode 信息
    "commit_footer": false,
    "include_co_authored_by": false
  },
  "notification": {
    "force_enable": true
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "anthropic": 5,
      "openai": 15,
      "google": 5
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 3,
      "openai/gpt-5.4": 5,
      "openai/gpt-5.3-codex": 10
    }
  },
  "disabled_mcps": [
    "websearch"
  ],
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "disable_omo_env": false
  }
}
